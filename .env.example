# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://media_hub_usr:change_me@localhost:5432/media_hub

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AWS S3 ─────────────────────────────────────────────────────────────────────
S3_BUCKET=cdn.digital-ai.tech
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_PREFIX=media-hub
CDN_BASE_URL=https://cdn.digital-ai.tech

# ── API Server ─────────────────────────────────────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0
# Admin API Key (SHA-256 hash of the actual key used for admin endpoints)
# Generate with: echo -n "your_admin_key" | sha256sum
ADMIN_API_KEY=sha256_hash_of_admin_key
# CORS: comma-separated list of allowed origins. Use * for all (not recommended in prod)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Worker ─────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2

# ── General ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
